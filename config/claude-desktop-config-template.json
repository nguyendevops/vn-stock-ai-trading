{
  "mcpServers": {
    "tradingview": {
      "command": "node",
      "args": [
        "C:\\Users\\<YOUR_USERNAME>\\tradingview-mcp\\src\\server.js"
      ]
    },
    "vnstock": {
      "command": "python",
      "args": ["-m", "vnstock_agent.server"],
      "env": {
        "VNSTOCK_API_KEY": "your_api_key_here"
      }
    },
    "tavily": {
      "command": "npx",
      "args": ["-y", "mcp-remote", "https://mcp.tavily.com/mcp/?tavilyApiKey=your_tavily_api_key_here"]
    }
  }
}
